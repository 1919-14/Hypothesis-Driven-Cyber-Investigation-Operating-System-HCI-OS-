# HCI-OS — Unified Master Environment Variables Template
# Copy this to .env and configure local secrets. Do NOT commit the .env file.

# ── Flask / Backend Server ──────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-before-production
LOG_LEVEL=INFO

# ── SocketIO & CORS ─────────────────────────────────────────────
SOCKETIO_ASYNC_MODE=threading
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# ── HTTP Request Settings ──────────────────────────────────────
REQUEST_TIMEOUT_S=10
MAX_RETRIES=3

# ── MySQL Database ─────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=hci_os
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here

# ── Groq LLM API Credentials ──────────────────────────────────
# Active Groq Key (loaded dynamically by App, A6 and A8)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Neo4j Knowledge Graph Store (DS3) ──────────────────────────
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=hcios

# ── Elasticsearch Log Store (DS5) ──────────────────────────────
ELASTICSEARCH_HOSTS=http://localhost:9200
ELASTICSEARCH_USER=
ELASTICSEARCH_PASSWORD=

# ── Performance Settings ───────────────────────────────────────
NAKSHATRA_ENABLE_TORCH_LSTM=1
